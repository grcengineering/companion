#!/usr/bin/env python3
"""Compatibility wrapper for the old docs build step."""

from __future__ import annotations

import runpy
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]


def main() -> None:
    runpy.run_path(str(ROOT / "scripts" / "build-card-pages"), run_name="__main__")


if __name__ == "__main__":
    main()
