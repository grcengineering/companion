#!/usr/bin/env python3
"""Cluster private candidates and draft review briefs.

This script emits one YAML brief per cluster. It intentionally does not draft
full cards; briefs are private review artifacts for later human distillation.
"""

from __future__ import annotations

import argparse
import json
import re
from collections import Counter, defaultdict
from pathlib import Path
from typing import Any

ROOT = Path(__file__).resolve().parents[1]
DEFAULT_CANDIDATES = ROOT / "_candidates" / "candidates.jsonl"
DEFAULT_OUT_DIR = ROOT / "_briefs"

CARD_TYPES = ("thesis", "concept", "metaphor", "anti_pattern", "reading_reference")

