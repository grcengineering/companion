    "vendor",
}


def useful_phrase(phrase: str) -> bool:
    return (
        phrase
        and phrase not in GENERIC_DYNAMIC_PHRASES
        and not phrase.startswith("the ")
        and not phrase.startswith("you ")
        and not any(part in phrase for part in BANNED_DYNAMIC_PARTS)
        and any(term in phrase for term in DYNAMIC_SIGNAL_TERMS)
    )

