#!/usr/bin/env python3
"""Verify Companion source-of-truth structure."""

from __future__ import annotations

import json
import re
import sys
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
SKILL_NAME_RE = re.compile(r"^[a-z]+(?:-[a-z]+)*$")


def require(path: str) -> None:
    if not (ROOT / path).exists():
        raise AssertionError(f"missing {path}")


def skill_frontmatter(path: Path) -> tuple[dict[str, str], str]:
    text = path.read_text(encoding="utf-8")
    if not text.startswith("---\n"):
        raise AssertionError(f"{path.relative_to(ROOT)} missing YAML frontmatter")
    parts = text.split("---", 2)
    if len(parts) < 3:
        raise AssertionError(f"{path.relative_to(ROOT)} has invalid YAML frontmatter")
    data: dict[str, str] = {}
    for line in parts[1].splitlines():
        if ":" in line:
            key, value = line.split(":", 1)
            data[key.strip()] = value.strip()
    for required in ("name", "description"):
        if not data.get(required):
            raise AssertionError(f"{path.relative_to(ROOT)} missing frontmatter field: {required}")
    return data, parts[2]


def main() -> int:
    required = [
        "brain/persona.md",
        "brain/voice.md",
        "brain/learning-method.md",
        "brain/skill-router.md",
        "brain/task-extraction.md",
        "brain/cross-domain-transfer.md",
        "brain/local-work-learning.md",
        "AGENTS.md",
        "SECURITY.md",
        "commands/README.md",
        "profile/learner-profile.schema.json",
        "profile/examples/anonymous-learner.json",
        "demos/terminal-session.md",
        "demos/run-terminal-demo",
        "knowledge/index.json",
        "docs/_templates/card.html",
        "docs/_templates/index.html",
        "docs/_templates/install.html",
        "docs/_templates/roadmap.html",
        "docs/data/cards.json",
        "docs/install.html",
        "docs/roadmap.html",
        "docs/cards/thesis-grc-as-product.html",
        "scripts/build-adapters",
        "scripts/build-card-pages",
        "scripts/sync-skill-manifests",
        "evals/suites.json"
    ]
    for path in required:
        require(path)

    skill_dirs = [p for p in (ROOT / "skills").iterdir() if p.is_dir()]
    if not skill_dirs:
        raise AssertionError("no skills found")

    for skill in skill_dirs:
        for filename in ("SKILL.md", "manifest.json", "INSTALL.md", "VERIFY.md"):
            require(f"skills/{skill.name}/{filename}")
        frontmatter, body = skill_frontmatter(skill / "SKILL.md")
        if frontmatter["name"] != skill.name:
            raise AssertionError(f"{skill.name} frontmatter name does not match directory")
        if not SKILL_NAME_RE.fullmatch(frontmatter["name"]):
            raise AssertionError(f"{skill.name} frontmatter name must be lowercase hyphenated words")
        description = frontmatter["description"]
        for phrase in ("USE WHEN", "NOT FOR"):
            if phrase not in description:
                raise AssertionError(f"{skill.name} description missing {phrase}")
        required_sections = [
            "## What",
            "## When",
            "## Not For",
            "## Inputs",
            "## Steps",
            "## Validation",
            "## Gotchas",
            "## Failure Modes",
            "## Examples",
        ]
        for section in required_sections:
            if section not in body:
                raise AssertionError(f"{skill.name} missing {section}")
        if "placeholder" in body.lower():
            raise AssertionError(f"{skill.name} still contains placeholder text")
        manifest = json.loads((skill / "manifest.json").read_text(encoding="utf-8"))
        if manifest.get("name") != frontmatter["name"]:
            raise AssertionError(f"{skill.name} manifest name is out of sync with SKILL.md")
        if manifest.get("description") != frontmatter["description"]:
            raise AssertionError(f"{skill.name} manifest description is out of sync with SKILL.md")
        if manifest.get("operational_scope") != "forbidden":
            raise AssertionError(f"{skill.name} does not forbid operational scope")
        if len(manifest.get("learning_principles", [])) < 3:
            raise AssertionError(f"{skill.name} has fewer than 3 learning principles")

    command_files = [p for p in (ROOT / "commands").glob("*.md") if p.name != "README.md"]
    if not command_files:
        raise AssertionError("no commands found")

    print(f"OK structure: {len(skill_dirs)} skills, {len(command_files)} commands")
    return 0


if __name__ == "__main__":
    try:
        raise SystemExit(main())
    except AssertionError as exc:
        print(f"FAIL {exc}", file=sys.stderr)
        raise SystemExit(1)
