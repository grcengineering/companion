#!/usr/bin/env python3
"""Build a lightweight file-based knowledge index."""

from __future__ import annotations

import json
from pathlib import Path

ROOT = Path(__file__).resolve().parents[1]
KNOWLEDGE = ROOT / "knowledge"
OUT = KNOWLEDGE / "index.json"


def first_heading(text: str, fallback: str) -> str:
    for line in text.splitlines():
        if line.startswith("# "):
            return line[2:].strip()
    return fallback


def first_paragraph(text: str) -> str:
    chunks = []
    for line in text.splitlines():
        stripped = line.strip()
        if not stripped or stripped.startswith("#"):
            if chunks:
                break
            continue
        if stripped.startswith("```"):
            break
        chunks.append(stripped)
    return " ".join(chunks)[:500]


def infer_type(path: Path) -> str:
    rel = path.relative_to(KNOWLEDGE)
    return rel.parts[0] if len(rel.parts) > 1 else "knowledge"


def main() -> None:
    entries = []
    for path in sorted(KNOWLEDGE.rglob("*.md")):
        if path.name == "index.json":
            continue
        text = path.read_text(encoding="utf-8")
        rel = path.relative_to(ROOT).as_posix()
        entries.append(
            {
                "id": rel.removesuffix(".md").replace("/", ":"),
                "title": first_heading(text, path.stem.replace("-", " ").title()),
                "path": rel,
                "type": infer_type(path),
                "summary": first_paragraph(text),
                "topics": [],
                "learning_uses": []
            }
        )

    OUT.write_text(json.dumps({"entries": entries}, indent=2) + "\n", encoding="utf-8")
    print(f"wrote {OUT.relative_to(ROOT)} ({len(entries)} entries)")


if __name__ == "__main__":
    main()
