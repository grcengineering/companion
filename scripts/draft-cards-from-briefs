def wrap(text: str) -> str:
    return textwrap.fill(" ".join(text.split()), width=88)


def read_brief(slug: str) -> dict:
    path = BRIEFS / f"brief-{slug}.yaml"
    with path.open() as f:
        return yaml.safe_load(f)


def clean_quote(snippet: str) -> str:
    text = re.sub(r"\s+", " ", snippet).strip()
    text = re.sub(r"[*_`#|\\-]+", "", text).strip()
    words = text.split()
    return " ".join(words[:18])


def frontmatter(card: dict) -> str:
    fields = {
        "schema_version": 1,
        "slug": card["slug"],
        "title": card["title"],
        "card_type": card["type"],
        "status": "draft",
        "source_basis": card["source_basis"],
        "derived_from": card.get("derived_from", []),
        "expands_brain_primitive": card.get("expands", []),
        "related_cards": card.get("related", []),
        "citation_id": card["slug"],
        "public_reference": card.get("public_reference", []),
        "reviewed_by": "",
        "reviewed_at": "",
    }
    if card["type"] == "reading_reference":
        fields["public_url"] = card["public_url"]
    return "---\n" + yaml.safe_dump(fields, sort_keys=False, allow_unicode=False) + "---\n\n"


def body_standard(card: dict) -> str:
    depth = (
        f"In the Companion, this is a reusable teaching card rather than a definition. "
        f"It should help the learner move from a familiar surface problem into the "
        f"deeper operating pattern: what is being optimised, what evidence exists, "
        f"who owns the behaviour, how the system learns, and where the boundary sits "
        f"between learning support and running the programme. When the learner brings "
        f"real local work, the Companion can use {card['title']} to name what happened, "
        f"extract a transferable principle, and leave the learner with a sharper next "
        f"move. When the learner has no live context, the same card can drive a "
        f"synthetic lab or scenario without pretending to operate their environment. "
        f"The output should be practical, named, and reusable."
    )
    sections = [
        f"# {card['title']}",
        "## Core Idea\n\n" + wrap(card["core"]) + "\n\n" + wrap(depth),
        "## Use In Teaching\n\n" + wrap(card["use"]),
        "## Contrast\n\n" + wrap(card["contrast"]),
        "## Practice Prompt\n\n" + wrap(card["practice"]),
    ]
    quotes = card.get("quotes", [])
    if quotes:
        sections.append("## Notable Quotes\n\n" + "\n".join(f"- \"{quote}\"" for quote in quotes[:2]))
    return "\n\n".join(sections) + "\n"


def body_reference(card: dict) -> str:
    return f"# {card['title']}\n\n{wrap(card['lede'])}\n\nCitation pointer: {card['public_url']}\n"


def derived_card(slug: str, promoted_slug: str | None = None) -> dict:
    spec = DERIVED[promoted_slug or slug]
    brief_slug = slug
    brief = read_brief(brief_slug)
    source_evidence = brief.get("source_evidence", [])
    source_ids = [item["source_id"] for item in source_evidence[:5]]
    related = spec.get("related") or brief.get("suggested_related_cards") or []
    card_slug = promoted_slug or brief["proposed_slug"]
    quotes = [clean_quote(item["snippet"]) for item in source_evidence[:2]]
    return {
        "slug": card_slug,
        "type": spec["type"],
        "title": spec["title"],
        "source_basis": "derived",
        "derived_from": source_ids,
        "expands": spec["expands"],
        "related": related,
        "public_reference": [],
        "core": spec["core"],
        "use": spec["use"],
        "contrast": spec["contrast"],
        "practice": spec["practice"],
        "quotes": quotes,
    }


def authored_cards() -> list[dict]:
    cards = []
    for spec in AUTHORED:
        cards.append({"source_basis": "authored", "related": [], **spec})
    for spec in READING_REFERENCES:
        cards.append(
            {
                "slug": spec["slug"],
                "type": "reading_reference",
                "title": spec["title"],
                "source_basis": "authored",
                "derived_from": spec["derived_from"],
                "expands": spec["expands"],
                "related": spec["related"],
                "public_reference": [spec["public_url"]],
                "public_url": spec["public_url"],
                "lede": spec["lede"],
            }
        )
    return cards


def build_cards() -> list[dict]:
    derived_specs = [
        "evidence-as-byproduct",
        "compliance-theatre",
        "audit-driven-thinking",
        "tool-first-automation",
        "grc-as-git",
        "human-api",
        "policy-as-interface",
        "ai-grc-workflows",
        "continuous-assurance",
        "control-design",
        "enterprise-grc-automation",
        "framework-translation",
        "risk-as-code",
        "vendor-review-learning",
    ]
    cards = [derived_card(slug) for slug in derived_specs]
    cards.append(derived_card("phrase-risk-register", "risk-register"))
    cards.append(derived_card("phrase-risk-quantification", "risk-quantification"))
    cards.append(derived_card("phrase-trust-center", "trust-center"))
    cards.extend(authored_cards())
    return cards


def write_card(card: dict) -> Path:
    target_dir = DRAFTS / card["type"]
    target_dir.mkdir(parents=True, exist_ok=True)
    path = target_dir / f"{card['slug']}.md"
    body = body_reference(card) if card["type"] == "reading_reference" else body_standard(card)
    path.write_text(frontmatter(card) + body, encoding="utf-8")
    return path


def main() -> None:
    if not BRIEFS.exists():
        raise SystemExit("_briefs/ is missing. Run scripts/draft-briefs first.")
    paths = [write_card(card) for card in build_cards()]
    by_type: dict[str, int] = {}
    for path in paths:
        by_type[path.parent.name] = by_type.get(path.parent.name, 0) + 1
    print(f"wrote {len(paths)} cards to _drafts")
    for key in sorted(by_type):
        print(f"{key}: {by_type[key]}")
    for path in sorted(paths):
        print(path.relative_to(ROOT))


if __name__ == "__main__":
    main()
